{
    "urls": "http://*:9291",
    // ==================== 数据库连接配置 ====================
    "DbConnection": {
        // 数据库连接字符串
        "ConnectionString": "Data Source=.;Initial Catalog=WIDESEAWMS_TEST_NEW;User ID=sa;Password=P@ssw0rd;Integrated Security=False;Connect Timeout=30;Encrypt=False;TrustServerCertificate=False;ApplicationIntent=ReadWrite;MultiSubnetFailover=False;MultipleActiveResultSets=True",
        // 数据库类型: SqlServer, MySql, SQLite, PostgreSQL
        "DbType": "SqlServer",
        // 是否启用 SQL 日志
        "EnableSqlLog": true,
        // 命令超时时间（秒）
        "CommandTimeout": 30,
        // 配置库 SQLite 文件路径（相对或绝对路径，默认 Data/kh-wms-config.db）
        "ConfigDbPath": "Data/kh-wms-config.db"
    },

    // ==================== CORS 跨域配置 ====================
    "Cors": {
        // 是否允许任何来源（true=允许所有，false=使用 AllowedOrigins 列表）
        "AllowAnyOrigin": false,
        // 允许的来源列表（当 AllowAnyOrigin 为 false 时生效）
        "AllowedOrigins": [
            "http://localhost:3000",
            "http://localhost:8080",
            "https://localhost:3000",
            "https://localhost:8080"
        ],
        // 是否允许任何 HTTP 方法（GET, POST, PUT, DELETE 等）
        "AllowAnyMethod": true,
        // 是否允许任何请求头
        "AllowAnyHeader": true,
        // 暴露给客户端的响应头
        "ExposedHeaders": [
            "X-Correlation-ID",
            "X-Request-ID"
        ],
        // 是否设置预检请求（OPTIONS）的缓存时间
        "SetPreflightMaxAge": true,
        // 预检请求的最大缓存时间（秒）
        "PreflightMaxAgeSeconds": 600
    },

    // ==================== Swagger API 文档配置 ====================
    "Swagger": {
        // API 文档标题
        "Title": "KH.WMS API",
        // API 版本
        "Version": "v1",
        // API 描述
        "Description": "KH.WMS API 接口文档",
        // 联系人名称
        "ContactName": "",
        // 联系人邮箱
        "ContactEmail": "",
        // 联系人 URL
        "ContactUrl": "",
        // 许可证名称
        "LicenseName": "",
        // 许可证 URL
        "LicenseUrl": "",
        // Swagger UI 访问路径前缀（空字符串表示根路径）
        "RoutePrefix": "swagger",
        // 是否启用 JWT 认证
        "EnableJwt": true
    },

    // ==================== MiniProfiler 性能分析配置 ====================
    "MiniProfiler": {
        // MiniProfiler 路由基础路径
        "RouteBasePath": "/profiler",
        // 是否在生产环境启用
        "EnableInProduction": false,
        // 是否跟踪数据库连接的打开/关闭
        "TrackConnectionOpenClose": true,
        // 堆栈跟踪长度
        "StackTraceLength": 5
    },

    // ==================== RateLimit 限流配置 ====================
    "RateLimit": {
        // 时间窗口内允许的请求数
        "RequestLimit": 100,
        // 时间窗口（秒）
        "WindowSeconds": 60,
        // 缓存键前缀
        "KeyPrefix": "ratelimit"
    },

    // ==================== 应用配置 ====================
    "App": {
        // 应用名称
        "AppName": "KH.WMS"
    },

    // ==================== JWT 认证配置 ====================
    // 注意：Secret 为敏感配置，下方为开发占位值，生产环境务必替换为独立的高强度密钥
    // （长度至少 32 位）。更换 Secret 会使所有已签发 token 失效（用户需重新登录）。
    "Jwt": {
        "Secret": "Z9k7Vq2mXc8Rf3Lp1Wd6Hj4Nb0Tg5Ys8Ka2Mx7Cv9Bn3Qw1Er6Ty8Uu2Io5Pa9Sd4",
        "Issuer": "KH.WMS",
        "Audience": "KH.WMS",
        "AccessTokenExpirationMinutes": 30,
        "RefreshTokenExpirationDays": 7,
        "ClockSkewSeconds": 5,
        "ValidateIssuer": true,
        "ValidateAudience": true,
        "ValidateLifetime": true
    },

    // ==================== DataMap 入站接口鉴权 ====================
    // 外部系统（ERP/MES）调用入站接口时必须在请求头携带 X-Interface-Key: <此值>。
    // 留空则所有入站接口一律拒绝（fail-closed）。下方为开发占位值，生产环境务必替换。
    "DataMap": {
        "InboundApiKey": "kh-wms-inbound-2026-dev-key-please-change-in-production"
    },

    // ==================== Serilog 日志配置 ====================
    "Serilog": {
        // 最低日志级别
        "MinimumLevel": {
            // 默认级别: Debug, Information, Warning, Error, Fatal
            "Default": "Debug",
            // 覆盖特定命名空间的日志级别
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.Hosting.Lifetime": "Information",
                "Microsoft.EntityFrameworkCore": "Warning",
                "System": "Warning"
            }
        },
        // 日志文件存储路径
        "LogPath": "Logs",
        // 日志保留天数
        "RetentionDays": 30,
        // 单个日志文件最大大小（MB）
        "MaxFileSizeMB": 5,
        // 是否输出到控制台
        "WriteToConsole": true,
        // 日志文件名配置
        "FileNames": {
            // 普通日志文件名
            "Log": "log",
            // 错误日志文件名
            "Error": "error",
            // 警告日志文件名
            "Warning": "warning"
        }
    }
}
